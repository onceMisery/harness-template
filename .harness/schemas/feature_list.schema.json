{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FeatureList",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "name",
      "module",
      "type",
      "priority",
      "status",
      "passes",
      "dependencies",
      "acceptance_criteria",
      "test_scope",
      "owner",
      "last_eval_score",
      "notes"
    ],
    "properties": {
      "id": {"type": "string"},
      "name": {"type": "string"},
      "module": {"type": "string"},
      "type": {"type": "string"},
      "priority": {"type": "string", "enum": ["P0", "P1", "P2", "P3"]},
      "status": {"type": "string", "enum": ["planned", "in_progress", "evaluating", "passed", "failed", "deferred"]},
      "passes": {"type": "boolean"},
      "dependencies": {"type": "array", "items": {"type": "string"}},
      "inputs": {"type": "array", "items": {"type": "string"}},
      "outputs": {"type": "array", "items": {"type": "string"}},
      "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string"}},
      "test_scope": {"type": "array", "items": {"type": "string", "enum": ["unit", "integration", "contract", "e2e"]}},
      "owner": {"type": "string"},
      "last_eval_score": {"type": "number", "minimum": 0, "maximum": 100},
      "notes": {"type": "string"}
    },
    "additionalProperties": true
  }
}
